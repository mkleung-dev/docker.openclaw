# OpenClaw environment configuration
# Copy this file to .env and fill values:
# cp .env.example .env

# OpenClaw Docker image to use
OPENCLAW_IMAGE=openclaw:local

# Gateway access token for authentication
# Leave empty for insecure mode (development only)
OPENCLAW_GATEWAY_TOKEN=

# Allow insecure private WebSocket connections
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

# Claude.ai authentication (optional, for Claude AI provider)
CLAUDE_AI_SESSION_KEY=

# Claude Web authentication (optional, for Claude Web provider)
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Gateway and Bridge port mappings
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Gateway bind address (lan, localhost, or specific IP)
OPENCLAW_GATEWAY_BIND=lan

# Timezone for the services
OPENCLAW_TZ=UTC

# Docker group ID for sandbox isolation
# Get it with: stat -c '%g' /var/run/docker.sock
# Only needed if enabling sandbox volumes (uncomment in docker-compose.yml)
DOCKER_GID=999

# Volume names (optional customization)
OPENCLAW_CONFIG_DIR=openclaw-config
OPENCLAW_WORKSPACE_DIR=openclaw-workspace
